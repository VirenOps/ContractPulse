generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  DEPT_HEAD
  CFO
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum AlertState {
  MONITORING
  ALERT_L1
  ALERT_L2
  ALERT_L3
  ACKNOWLEDGED
}

model Company {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())

  users     User[]
  contracts Contract[]
}

model User {
  id        String     @id @default(uuid())
  companyId String
  name      String
  email     String     @unique
  password  String
  role      Role       @default(MANAGER)
  createdAt DateTime   @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  contracts Contract[]
  auditLogs AuditLog[]
}

model Contract {
  id                 String           @id @default(uuid())
  companyId          String
  ownerId            String
  title              String?
  vendorName         String?
  contractType       String?
  totalValue         Float?
  currency           String           @default("INR")
  startDate          DateTime?
  endDate            DateTime?
  autoRenews         Boolean          @default(false)
  renewalTermDays    Int?
  noticeRequiredDays Int?
  noticeDeadline     DateTime?
  renewalDecision    String?
  decisionMadeAt     DateTime?
  decisionMadeBy     String?
  pdfUrl             String?
  rawText            String?
  extractedData      Json?
  processingStatus   ProcessingStatus @default(PENDING)
  alertState         AlertState       @default(MONITORING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  owner          User            @relation(fields: [ownerId], references: [id])
  milestones     Milestone[]
  penaltyClauses PenaltyClause[]
  auditLogs      AuditLog[]
}

model Milestone {
  id             String   @id @default(uuid())
  contractId     String
  description    String
  dueDate        DateTime
  isRecurring    Boolean  @default(false)
  recurrenceRule String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
}

model PenaltyClause {
  id               String   @id @default(uuid())
  contractId       String
  description      String
  amount           Float?
  triggerCondition String?

  contract Contract @relation(fields: [contractId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  contractId String
  userId     String?
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
}